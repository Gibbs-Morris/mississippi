@namespace MississippiSamples.LightSpeed.Client.OperationsWorkbench

<main class="ls-workbench">
<header class="ls-workbench__hero">
    <div class="ls-workbench__hero-copy">
        <p class="ls-workbench__eyebrow">@Model.RouteEyebrow</p>
        <h1 class="ls-workbench__title">Operations workbench</h1>
        <p class="ls-workbench__subtitle">
            @Model.RouteSubtitle
        </p>
    </div>

    <section class="ls-workbench__brand-switcher" aria-label="Brand switcher">
        <span class="ls-workbench__brand-label">Brand</span>
        @foreach (string brandOption in Model.BrandOptions)
        {
            <button type="button"
                    class="ls-brand-button @(IsActiveBrand(brandOption) ? "is-active" : string.Empty)"
                    aria-pressed="@IsActiveBrand(brandOption)"
                    data-testid="brand-@brandOption"
                    @onclick="() => OnBrandChanged.InvokeAsync(brandOption)">
                @OperationsWorkbenchScenario.GetBrandLabel(brandOption)
            </button>
        }
    </section>
</header>

<StatusSummaryBar AdditionalAttributes="@StatusSummaryBarAttributes">
    <span class="ls-workbench__metric">Queue @Model.QueueCount</span>
    <span class="ls-workbench__metric">Ready @Model.ReadyItemCount</span>
    <span class="ls-workbench__metric">Actioned @Model.ActionedItemCount</span>
    <span class="ls-workbench__metric">Selected @Model.CurrentSelectionStage</span>
    <span class="ls-workbench__metric">Theme @Model.CurrentBrandLabel</span>
</StatusSummaryBar>

@if (!string.IsNullOrWhiteSpace(Model.FeedbackMessage))
{
    <TelemetryStrip aria-live="polite"
                    class="@($"ls-workbench__feedback ls-workbench__feedback--{Model.FeedbackTone}")"
                    data-testid="feedback-banner"
                    State="@Model.FeedbackTone">
        @Model.FeedbackMessage
    </TelemetryStrip>
}

<div class="ls-workbench__layout">
    <SurfacePanel Title="Operations queue">
        <FilterBar class="ls-workbench__filters">
            <div class="ls-workbench__filter-field">
                <InputField Id="ls-queue-search"
                            Label="Search queue"
                            Placeholder="Search by id, customer, queue, or analyst"
                            Value="@Model.SearchText"
                            ValueChanged="OnSearchChanged"/>
            </div>

            <div class="ls-workbench__filter-field">
                <label class="ls-workbench__field-label" for="ls-stage-filter">Stage</label>
                <select id="ls-stage-filter"
                        class="ls-workbench__select"
                        data-testid="stage-filter"
                        value="@Model.SelectedStageFilter"
                        @onchange="HandleStageFilterChangedAsync">
                    @foreach (string stageOption in Model.StageFilterOptions)
                    {
                        <option value="@stageOption">@stageOption</option>
                    }
                </select>
            </div>
        </FilterBar>

        <div class="ls-workbench__queue-shell">
            @if (Model.VisibleWorkItems.Count == 0)
            {
                <EmptyState class="ls-workbench__empty-state"
                            data-testid="queue-empty-state"
                            Message="No work items match the current search and stage filter."/>
            }
            else
            {
                <table class="ls-workbench__table">
                    <thead>
                    <tr>
                        <th scope="col">Work item</th>
                        <th scope="col">Queue</th>
                        <th scope="col">Analyst</th>
                        <th scope="col">Stage</th>
                        <th scope="col">Checkpoint</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (OperationsWorkbenchItem item in Model.VisibleWorkItems)
                    {
                        <tr class="ls-workbench__table-row @(item.Id == Model.SelectedWorkItem?.Id ? "is-selected" : string.Empty)"
                            data-selected="@(item.Id == Model.SelectedWorkItem?.Id)">
                            <td>
                                <button type="button"
                                        class="ls-workbench__row-button"
                                        data-testid="queue-select-@item.Id"
                                        @onclick="() => OnSelectionChanged.InvokeAsync(item.Id)">
                                    <span class="ls-workbench__row-title">@item.Id</span>
                                    <span class="ls-workbench__row-subtitle">@item.Customer</span>
                                </button>
                            </td>
                            <td>@item.Queue</td>
                            <td>@item.AssignedAnalyst</td>
                            <td>
                                <StatusBadge class="@($"ls-state-badge ls-state-badge--{OperationsWorkbenchScenario.GetStageCssSuffix(item.Stage)}")"
                                             Label="@item.Stage"/>
                            </td>
                            <td>@item.LastCheckpoint</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </SurfacePanel>

    <SurfacePanel Title="Selected review">
        <ChildContent>
            @if (Model.SelectedWorkItem is null)
            {
                <EmptyState class="ls-workbench__empty-state"
                            data-testid="detail-empty-state"
                            Message="Select a queue item to inspect the current response plan."/>
            }
            else
            {
                <section class="ls-workbench__detail" data-testid="detail-panel">
                    <header class="ls-workbench__detail-header">
                        <div>
                            <p class="ls-workbench__detail-kicker">@Model.SelectedWorkItem.Queue</p>
                            <h2 class="ls-workbench__detail-title">@Model.SelectedWorkItem.Customer</h2>
                        </div>

                        <StatusBadge class="@($"ls-state-badge ls-state-badge--{OperationsWorkbenchScenario.GetStageCssSuffix(Model.SelectedWorkItem.Stage)}")"
                                     data-testid="selected-stage"
                                     Label="@Model.SelectedWorkItem.Stage"/>
                    </header>

                    <dl class="ls-workbench__detail-grid">
                        <div>
                            <dt>Work item</dt>
                            <dd data-testid="selected-id">@Model.SelectedWorkItem.Id</dd>
                        </div>
                        <div>
                            <dt>Analyst</dt>
                            <dd data-testid="selected-analyst">@Model.SelectedWorkItem.AssignedAnalyst</dd>
                        </div>
                        <div>
                            <dt>Disposition</dt>
                            <dd data-testid="selected-disposition">@Model.SelectedWorkItem.Disposition</dd>
                        </div>
                        <div>
                            <dt>Checkpoint</dt>
                            <dd data-testid="selected-checkpoint">@Model.SelectedWorkItem.LastCheckpoint</dd>
                        </div>
                    </dl>

                    <section class="ls-workbench__detail-section">
                        <h3>Response summary</h3>
                        <p data-testid="selected-summary">@Model.SelectedWorkItem.ResponseSummary</p>
                    </section>

                    <section class="ls-workbench__detail-section">
                        <h3>Review notes</h3>
                        <p data-testid="selected-notes">@Model.SelectedWorkItem.ReviewNotes</p>
                    </section>
                </section>
            }
        </ChildContent>

        <Footer>
            <ActionBar aria-label="Selected review actions"
                       class="ls-workbench__detail-actions">
                <CommandButton class="ls-command-button ls-command-button--secondary"
                               data-testid="review-open"
                               IsDisabled="@(Model.SelectedWorkItem is null)"
                               Label="Review and edit"
                               OnClick="OnReviewRequested"/>

                <CommandButton class="ls-command-button"
                               data-testid="apply-action"
                               IsDisabled="@(!Model.CanActSelectedWorkItem)"
                               Label="Apply action"
                               OnClick="OnActionRequested"/>
            </ActionBar>
        </Footer>
    </SurfacePanel>
</div>

@if (Model.IsReviewDialogOpen)
{
    <section aria-labelledby="ls-review-dialog-title"
             aria-modal="true"
             class="ls-review-dialog"
             data-testid="review-dialog"
             role="dialog">
        <div class="ls-review-dialog__backdrop"></div>
        <div class="ls-review-dialog__surface">
            <header class="ls-review-dialog__header">
                <div>
                    <p class="ls-review-dialog__eyebrow">Review and validate</p>
                    <h2 id="ls-review-dialog-title">Update the response plan</h2>
                </div>

                <button type="button"
                        aria-label="Close review dialog"
                        class="ls-review-dialog__close"
                        @onclick="OnReviewCanceled">
                    ×
                </button>
            </header>

            @if (Model.ValidationMessages.Count > 0)
            {
                <div aria-live="assertive"
                     class="ls-review-dialog__validation-summary"
                     data-testid="validation-summary"
                     role="alert">
                    <p>Resolve the following before saving:</p>
                    <ul>
                        @foreach (string validationMessage in Model.ValidationMessages)
                        {
                            <li>@validationMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="ls-review-dialog__form-grid">
                <div class="ls-workbench__field">
                    <InputField Id="ls-review-analyst"
                                Label="Assigned analyst"
                                Placeholder="Assign analyst"
                                Value="@Model.DraftAssignedAnalyst"
                                ValueChanged="OnDraftAssignedAnalystChanged"/>
                    @if (!string.IsNullOrWhiteSpace(Model.DraftAssignedAnalystError))
                    {
                        <p class="ls-workbench__field-error">@Model.DraftAssignedAnalystError</p>
                    }
                </div>

                <div class="ls-workbench__field">
                    <label class="ls-workbench__field-label" for="ls-review-disposition">Disposition</label>
                    <select id="ls-review-disposition"
                            class="ls-workbench__select"
                            data-testid="review-disposition"
                            value="@Model.DraftDisposition"
                            @onchange="HandleDraftDispositionChangedAsync">
                        @foreach (string dispositionOption in Model.DispositionOptions)
                        {
                            <option value="@dispositionOption">@dispositionOption</option>
                        }
                    </select>
                </div>

                <div class="ls-workbench__field ls-workbench__field--full-width">
                    <InputField Id="ls-review-summary"
                                Label="Response summary"
                                Placeholder="Summarize the operational plan"
                                Value="@Model.DraftResponseSummary"
                                ValueChanged="OnDraftResponseSummaryChanged"/>
                    @if (!string.IsNullOrWhiteSpace(Model.DraftResponseSummaryError))
                    {
                        <p class="ls-workbench__field-error">@Model.DraftResponseSummaryError</p>
                    }
                </div>

                <div class="ls-workbench__field ls-workbench__field--full-width">
                    <label class="ls-workbench__field-label" for="ls-review-notes">Review notes</label>
                    <textarea id="ls-review-notes"
                              class="ls-workbench__textarea"
                              data-testid="review-notes"
                              value="@Model.DraftReviewNotes"
                              @oninput="HandleDraftReviewNotesChangedAsync"></textarea>
                    @if (!string.IsNullOrWhiteSpace(Model.DraftReviewNotesError))
                    {
                        <p class="ls-workbench__field-error">@Model.DraftReviewNotesError</p>
                    }
                </div>
            </div>

            <ActionBar aria-label="Review dialog actions"
                       class="ls-review-dialog__actions">
                <CommandButton class="ls-command-button ls-command-button--secondary"
                               Label="Cancel"
                               OnClick="OnReviewCanceled"/>
                <CommandButton class="ls-command-button"
                               data-testid="review-save"
                               Label="Save review"
                               OnClick="OnReviewSaved"/>
            </ActionBar>
        </div>
    </section>
}
</main>