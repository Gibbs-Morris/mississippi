@inherits Mississippi.Refraction.Client.StateManagement.Scenes.ReservoirSceneBase<MississippiSamples.LightSpeed.Client.Features.ReservoirOperationsWorkbench.ReservoirOperationsWorkbenchState>

<RefractionRoot Selection="@ThemeSelection">
    <OperationsWorkbenchSurface Model="@ViewModel"
                                OnActionRequested="HandleActionRequestedAsync"
                                OnBrandChanged="HandleBrandChangedAsync"
                                OnDraftAssignedAnalystChanged="HandleDraftAssignedAnalystChangedAsync"
                                OnDraftDispositionChanged="HandleDraftDispositionChangedAsync"
                                OnDraftResponseSummaryChanged="HandleDraftResponseSummaryChangedAsync"
                                OnDraftReviewNotesChanged="HandleDraftReviewNotesChangedAsync"
                                OnReviewCanceled="HandleReviewCanceledAsync"
                                OnReviewRequested="HandleReviewRequestedAsync"
                                OnReviewSaved="HandleReviewSavedAsync"
                                OnSearchChanged="HandleSearchChangedAsync"
                                OnSelectionChanged="HandleSelectionChangedAsync"
                                OnStageFilterChanged="HandleStageFilterChangedAsync"/>
</RefractionRoot>