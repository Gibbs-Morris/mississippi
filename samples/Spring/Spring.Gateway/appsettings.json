{
  "SpringAuth": {
    "Enabled": false,
    "Scheme": "SpringLocalDev",
    "AnonymousHeader": "X-Spring-Anonymous",
    "UserHeader": "X-Spring-User",
    "RolesHeader": "X-Spring-Roles",
    "ClaimsHeader": "X-Spring-Claims",
    "DefaultUserId": "spring-local-user",
    "DefaultRoles": "banking-operator,transfer-operator",
    "DefaultClaims": ""
  },
  "SagaRecovery": {
    "Enabled": true,
    "ForceManualOnly": false,
    "InitialReminderDueTime": "00:01:00",
    "ReminderPeriod": "00:05:00",
    "MaxAutomaticAttempts": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
